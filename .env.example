# =============================================================================
# TechShop E-Commerce Platform - Root Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================================

# -----------------------------------------------------------------------------
# Docker Compose Configuration
# -----------------------------------------------------------------------------
COMPOSE_PROJECT_NAME=techshop

# -----------------------------------------------------------------------------
# Common Database Credentials
# -----------------------------------------------------------------------------
MYSQL_ROOT_PASSWORD=root
MYSQL_USER=techshop
MYSQL_PASSWORD=techshop
POSTGRES_USER=techshop
POSTGRES_PASSWORD=techshop

# -----------------------------------------------------------------------------
# Identity Service Database (MySQL)
# -----------------------------------------------------------------------------
IDENTITY_DB_NAME=identity_db
IDENTITY_DB_HOST=identity-mysql
IDENTITY_DB_PORT=3306

# -----------------------------------------------------------------------------
# Payment Service Database (MySQL)
# -----------------------------------------------------------------------------
PAYMENT_DB_NAME=payment_db
PAYMENT_DB_HOST=payment-mysql
PAYMENT_DB_PORT=3306

# -----------------------------------------------------------------------------
# Catalog Service Database (PostgreSQL)
# -----------------------------------------------------------------------------
CATALOG_DB_NAME=catalog_db
CATALOG_DB_HOST=catalog-postgres
CATALOG_DB_PORT=5432

# -----------------------------------------------------------------------------
# Cart Service Database (PostgreSQL)
# -----------------------------------------------------------------------------
CART_DB_NAME=cart_db
CART_DB_HOST=cart-postgres
CART_DB_PORT=5432

# -----------------------------------------------------------------------------
# Order Service Database (PostgreSQL)
# -----------------------------------------------------------------------------
ORDER_DB_NAME=order_db
ORDER_DB_HOST=order-postgres
ORDER_DB_PORT=5432

# -----------------------------------------------------------------------------
# Shipping Service Database (PostgreSQL)
# -----------------------------------------------------------------------------
SHIPPING_DB_NAME=shipping_db
SHIPPING_DB_HOST=shipping-postgres
SHIPPING_DB_PORT=5432

# -----------------------------------------------------------------------------
# Review Service Database (PostgreSQL)
# -----------------------------------------------------------------------------
REVIEW_DB_NAME=review_db
REVIEW_DB_HOST=review-postgres
REVIEW_DB_PORT=5432

# -----------------------------------------------------------------------------
# AI Service Database (PostgreSQL + pgvector)
# -----------------------------------------------------------------------------
AI_DB_NAME=ai_db
AI_DB_HOST=ai-postgres
AI_DB_PORT=5432

# -----------------------------------------------------------------------------
# JWT Configuration
# -----------------------------------------------------------------------------
JWT_ISSUER=techshop.identity
# Path to JWT public key (shared across services for token validation)
JWT_PUBLIC_KEY_PATH=/app/keys/jwt_public.pem
# Path to JWT private key (identity-service only)
JWT_PRIVATE_KEY_PATH=/app/keys/jwt_private.pem

# -----------------------------------------------------------------------------
# Application Settings
# -----------------------------------------------------------------------------
APP_ENV=development
DEBUG=True
SECRET_KEY=change-me-to-a-random-secret-key
ALLOWED_HOSTS=*
LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# Service URLs (internal Docker network)
# -----------------------------------------------------------------------------
IDENTITY_SERVICE_URL=http://identity-service:8001
CATALOG_SERVICE_URL=http://catalog-service:8002
CART_SERVICE_URL=http://cart-service:8003
ORDER_SERVICE_URL=http://order-service:8004
PAYMENT_SERVICE_URL=http://payment-service:8005
SHIPPING_SERVICE_URL=http://shipping-service:8006
REVIEW_SERVICE_URL=http://review-service:8007
AI_SERVICE_URL=http://ai-service:8010

# -----------------------------------------------------------------------------
# Gateway Configuration
# -----------------------------------------------------------------------------
GATEWAY_PORT=80

# -----------------------------------------------------------------------------
# Frontend Configuration
# -----------------------------------------------------------------------------
FRONTEND_PORT=3000
VITE_API_BASE_URL=http://localhost/api
