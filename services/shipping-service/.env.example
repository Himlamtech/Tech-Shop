# =============================================================================
# Shipping Service - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================================

# -----------------------------------------------------------------------------
# Application Settings
# -----------------------------------------------------------------------------
APP_ENV=development
DEBUG=True
SECRET_KEY=change-me-to-a-random-secret-key
ALLOWED_HOSTS=*
LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# Database Configuration (PostgreSQL)
# -----------------------------------------------------------------------------
DATABASE_URL=postgres://techshop:techshop@shipping-postgres:5432/shipping_db

# -----------------------------------------------------------------------------
# JWT Configuration
# -----------------------------------------------------------------------------
JWT_PUBLIC_KEY=/app/keys/jwt_public.pem
JWT_ISSUER=techshop.identity

# -----------------------------------------------------------------------------
# Service URLs
# -----------------------------------------------------------------------------
IDENTITY_SERVICE_URL=http://identity-service:8001
CATALOG_SERVICE_URL=http://catalog-service:8002
CART_SERVICE_URL=http://cart-service:8003
ORDER_SERVICE_URL=http://order-service:8004
PAYMENT_SERVICE_URL=http://payment-service:8005
SHIPPING_SERVICE_URL=http://shipping-service:8006
REVIEW_SERVICE_URL=http://review-service:8007
AI_SERVICE_URL=http://ai-service:8010

# -----------------------------------------------------------------------------
# CORS Configuration
# -----------------------------------------------------------------------------
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost
