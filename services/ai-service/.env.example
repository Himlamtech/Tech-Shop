# =============================================================================
# AI Service - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================================

# -----------------------------------------------------------------------------
# Application Settings
# -----------------------------------------------------------------------------
APP_ENV=development
DEBUG=True
SECRET_KEY=change-me-to-a-random-secret-key
ALLOWED_HOSTS=*
LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# Database Configuration (PostgreSQL + pgvector)
# -----------------------------------------------------------------------------
DATABASE_URL=postgres://techshop:techshop@ai-postgres:5432/ai_db

# -----------------------------------------------------------------------------
# JWT Configuration
# -----------------------------------------------------------------------------
JWT_PUBLIC_KEY=/app/keys/jwt_public.pem
JWT_ISSUER=techshop.identity

# -----------------------------------------------------------------------------
# Service URLs
# -----------------------------------------------------------------------------
IDENTITY_SERVICE_URL=http://identity-service:8001
CATALOG_SERVICE_URL=http://catalog-service:8002
CART_SERVICE_URL=http://cart-service:8003
ORDER_SERVICE_URL=http://order-service:8004
PAYMENT_SERVICE_URL=http://payment-service:8005
SHIPPING_SERVICE_URL=http://shipping-service:8006
REVIEW_SERVICE_URL=http://review-service:8007
AI_SERVICE_URL=http://ai-service:8010

# -----------------------------------------------------------------------------
# LLM Configuration
# -----------------------------------------------------------------------------
LLM_PROVIDER=openai
LLM_API_KEY=your-llm-api-key-here
LLM_MODEL=gpt-4o-mini
LLM_MAX_TOKENS=1024
LLM_TEMPERATURE=0.3

# -----------------------------------------------------------------------------
# Embedding Configuration
# -----------------------------------------------------------------------------
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIMENSION=768
RAG_SIMILARITY_THRESHOLD=0.5

# -----------------------------------------------------------------------------
# ML Model Paths
# -----------------------------------------------------------------------------
SENTIMENT_MODEL_PATH=/app/ml/sentiment
SEQUENCE_MODEL_PATH=/app/ml/sequence_model
SEGMENTATION_MODEL_PATH=/app/ml/segmentation
CLASSIFICATION_MODEL_PATH=/app/ml/product_classifier

# -----------------------------------------------------------------------------
# Dataset Paths
# -----------------------------------------------------------------------------
AMAZON_REVIEWS_PATH=/app/data/amazon_reviews
RETAILROCKET_PATH=/app/data/retailrocket
UCI_RETAIL_PATH=/app/data/uci_retail
FAQ_KNOWLEDGE_BASE_PATH=/app/data/faq

# -----------------------------------------------------------------------------
# CORS Configuration
# -----------------------------------------------------------------------------
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost
