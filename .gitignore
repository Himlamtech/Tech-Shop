# =============================================================================
# TechShop E-Commerce Platform - Git Ignore
# =============================================================================

# -----------------------------------------------------------------------------
# Environment Variables (Security - Requirement 25.1)
# -----------------------------------------------------------------------------
.env
.env.local
.env.*.local
!.env.example

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
.eggs/
*.egg
.venv/
venv/
env/
.Python

# -----------------------------------------------------------------------------
# Django
# -----------------------------------------------------------------------------
*.log
local_settings.py
db.sqlite3
db.sqlite3-journal
media/

# -----------------------------------------------------------------------------
# Node.js / Frontend
# -----------------------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnp
.pnp.js

# -----------------------------------------------------------------------------
# Build Outputs
# -----------------------------------------------------------------------------
frontend/dist/
frontend/build/
*.js.map

# -----------------------------------------------------------------------------
# IDE / Editor
# -----------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# -----------------------------------------------------------------------------
# Docker
# -----------------------------------------------------------------------------
docker-compose.override.yml

# -----------------------------------------------------------------------------
# JWT Keys (sensitive)
# -----------------------------------------------------------------------------
keys/
*.pem
*.key

# -----------------------------------------------------------------------------
# ML Model Artifacts (large files)
# -----------------------------------------------------------------------------
*.h5
*.pkl
*.joblib
*.pt
*.bin
!*.bin.example

# -----------------------------------------------------------------------------
# Dataset Files (large files)
# -----------------------------------------------------------------------------
data/
datasets/

# -----------------------------------------------------------------------------
# Coverage Reports
# -----------------------------------------------------------------------------
htmlcov/
.coverage
.coverage.*
coverage.xml
*.cover

# -----------------------------------------------------------------------------
# Testing
# -----------------------------------------------------------------------------
.pytest_cache/
.tox/
.nox/

# -----------------------------------------------------------------------------
# Misc
# -----------------------------------------------------------------------------
*.bak
*.tmp
*.temp
